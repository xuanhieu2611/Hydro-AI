{
  "expo": {
    "name": "Hydro AI",
    "slug": "hydro-ai",
    "scheme": "hydroai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.xuanhieu2611.hydroai",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Hydro AI uses the camera to photograph your drink and estimate how much you've had. Photos are processed and discarded — only the volume is saved.",
        "NSPhotoLibraryUsageDescription": "Hydro AI lets you add a drink from your camera roll if you forgot to log it in the moment.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.xuanhieu2611.hydroai",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "Hydro AI uses the camera to photograph your drink and estimate how much you've had."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Hydro AI lets you add a drink from your camera roll if you forgot to log it in the moment."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/drop.wav",
            "./assets/sounds/nag.wav",
            "./assets/sounds/uongnuocdi.wav"
          ]
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.810226355490-glijvf8g95crsjle4cskptg801s5atc6"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4f8ef912-a5df-4dd8-b852-57c8372b4984"
      }
    },
    "owner": "xuanhieu2611",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4f8ef912-a5df-4dd8-b852-57c8372b4984"
    }
  }
}
